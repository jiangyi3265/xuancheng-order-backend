<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jiedan.mapper.JiedanSettingMapper">

    <resultMap id="SettingResult" type="com.ruoyi.jiedan.domain.JiedanSetting">
        <id     property="settingKey"   column="setting_key"   />
        <result property="settingValue" column="setting_value" />
    </resultMap>

    <select id="selectValue" parameterType="String" resultType="String">
        select setting_value from jiedan_setting where setting_key = #{key}
    </select>

    <select id="selectAll" resultMap="SettingResult">
        select setting_key, setting_value from jiedan_setting
    </select>

    <insert id="upsert">
        insert into jiedan_setting (setting_key, setting_value) values (#{key}, #{value})
        on duplicate key update setting_value = #{value}
    </insert>

</mapper>
