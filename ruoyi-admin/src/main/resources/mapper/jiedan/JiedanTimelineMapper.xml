<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.jiedan.mapper.JiedanTimelineMapper">

    <resultMap id="JiedanTimelineResult" type="com.ruoyi.jiedan.domain.JiedanTimeline">
        <id     property="id"          column="id"          />
        <result property="orderId"     column="order_id"    />
        <result property="userName"    column="user_name"   />
        <result property="type"        column="type"        />
        <result property="content"     column="content"     />
        <result property="attachments" column="attachments" />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <select id="selectByOrderId" parameterType="Long" resultMap="JiedanTimelineResult">
        select id, order_id, user_name, type, content, attachments, create_time
        from jiedan_timeline where order_id = #{orderId} order by id desc
    </select>

    <insert id="insert" parameterType="com.ruoyi.jiedan.domain.JiedanTimeline" useGeneratedKeys="true" keyProperty="id">
        insert into jiedan_timeline (order_id, user_name, type, content, attachments, create_time)
        values (#{orderId}, #{userName}, #{type}, #{content}, #{attachments}, #{createTime})
    </insert>

    <delete id="deleteByOrderId" parameterType="Long">
        delete from jiedan_timeline where order_id = #{orderId}
    </delete>

</mapper>
